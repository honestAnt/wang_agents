{
  "compilerOptions": {
    "target": "ES2017",
    "lib": ["dom", "dom.iterable", "esnext"],
    "allowJs": true,
    "skipLibCheck": true,
    "strict": true,
    "noEmit": true,
    "esModuleInterop": true,
    "module": "esnext",
    "moduleResolution": "bundler",
    "resolveJsonModule": true,
    "isolatedModules": true,
    "jsx": "react-jsx",
    "incremental": true,
    "paths": {
      "@enterprise-ai/ui": ["./packages/ui-components/src"],
      "@enterprise-ai/api-client": ["./packages/api-client/src"],
      "@enterprise-ai/auth": ["./packages/auth/src"],
      "@enterprise-ai/utils": ["./packages/utils/src"]
    }
  },
  "exclude": ["node_modules"]
}
