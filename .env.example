# ============================================================
# Enterprise AI Platform — Environment Variables Template
# Copy this file to .env and fill in real values
# ============================================================

# --- PostgreSQL ---
POSTGRES_HOST=localhost
POSTGRES_PORT=5432
POSTGRES_DB=wang_agent
POSTGRES_USER=wang_agent
POSTGRES_PASSWORD=change_me
DATABASE_URL="postgresql://${POSTGRES_USER}:${POSTGRES_PASSWORD}@${POSTGRES_HOST}:${POSTGRES_PORT}/${POSTGRES_DB}?schema=public"

# --- Redis ---
REDIS_HOST=localhost
REDIS_PORT=6379
REDIS_PASSWORD=
REDIS_URL="redis://${REDIS_HOST}:${REDIS_PORT}"

# --- MinIO / S3 ---
S3_ENDPOINT=http://localhost:9000
S3_REGION=us-east-1
S3_ACCESS_KEY_ID=minioadmin
S3_SECRET_ACCESS_KEY=change_me
S3_BUCKET_NAME=enterprise-ai-files

# --- Qdrant (Vector DB) ---
QDRANT_HOST=localhost
QDRANT_PORT=6333
QDRANT_GRPC_PORT=6334
QDRANT_API_KEY=

# --- OpenSearch ---
OPENSEARCH_HOST=localhost
OPENSEARCH_PORT=9200
OPENSEARCH_USERNAME=admin
OPENSEARCH_PASSWORD=change_me

# --- Keycloak ---
KEYCLOAK_HOST=localhost
KEYCLOAK_PORT=8080
KEYCLOAK_REALM=enterprise-ai-platform
KEYCLOAK_CLIENT_ID=enterprise-ai-client
KEYCLOAK_CLIENT_SECRET=change_me

# --- Kafka ---
KAFKA_BOOTSTRAP_SERVERS=localhost:9092
KAFKA_TOPIC_PREFIX=enterprise-ai

# --- LLM Provider API Keys (optional) ---
OPENAI_API_KEY=
ANTHROPIC_API_KEY=
GOOGLE_API_KEY=
DEEPSEEK_API_KEY=
QWEN_API_KEY=

# --- Jaeger (Observability) ---
JAEGER_ENDPOINT=http://localhost:4317
JAEGER_SERVICE_NAME=agent-python-runtime
JAEGER_INSECURE=true

# --- JWT ---
JWT_ISSUER_URI=http://${KEYCLOAK_HOST}:${KEYCLOAK_PORT}/realms/${KEYCLOAK_REALM}
JWT_JWK_SET_URI=${JWT_ISSUER_URI}/protocol/openid-connect/certs
