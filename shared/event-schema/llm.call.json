{
  "$schema": "https://json-schema.org/draft/2020-12/schema",
  "$id": "https://enterprise-ai-platform/schemas/events/v1/llm.call.json",
  "title": "LLM Call Event",
  "description": "Emitted each time the platform makes an LLM inference call. Consumed by trace-service and billing-service.",
  "type": "object",
  "required": ["event_id", "trace_id", "span_id", "tenant_id", "model", "provider", "timestamp"],
  "properties": {
    "event_id": { "type": "string", "format": "uuid" },
    "trace_id": { "type": "string", "format": "uuid" },
    "span_id": { "type": "string", "format": "uuid" },
    "parent_span_id": { "type": "string", "format": "uuid" },
    "tenant_id": { "type": "string" },
    "user_id": { "type": "string" },
    "agent_id": { "type": "string" },
    "session_id": { "type": "string" },
    "model": { "type": "string", "description": "e.g. gpt-4.1, claude-sonnet-4-6, deepseek-v3" },
    "provider": { "type": "string", "enum": ["openai", "anthropic", "google", "deepseek", "qwen", "vllm", "ollama"] },
    "messages": {
      "type": "array",
      "items": {
        "type": "object",
        "properties": {
          "role": { "type": "string", "enum": ["system", "user", "assistant", "tool"] },
          "content": { "type": "string" }
        }
      }
    },
    "temperature": { "type": "number" },
    "max_tokens": { "type": "integer" },
    "stream": { "type": "boolean" },
    "completion": { "type": "string", "description": "LLM response text." },
    "finish_reason": { "type": "string", "enum": ["stop", "length", "tool_calls", "content_filter"] },
    "prompt_tokens": { "type": "integer" },
    "completion_tokens": { "type": "integer" },
    "total_tokens": { "type": "integer" },
    "cost_usd": { "type": "number", "description": "Cost in USD for this call." },
    "cost_currency": { "type": "string", "default": "USD" },
    "latency_ms": { "type": "number" },
    "retry_count": { "type": "integer", "default": 0 },
    "fallback_used": { "type": "boolean", "default": false },
    "fallback_model": { "type": "string" },
    "status": { "type": "string", "enum": ["ok", "error", "timeout", "rate_limited"] },
    "error_message": { "type": "string" },
    "timestamp": { "type": "string", "format": "date-time" }
  }
}
